[RTL8125Miniport.CopyFiles]
rtl8125miniport.sys,,,2

[RTL8125Miniport.Service]
DisplayName   = %RTL8125Miniport.ServiceDesc%
ServiceType   = 1
StartType     = 3
ErrorControl  = 1
ServiceBinary = %13%\rtl8125miniport.sys

[RTL8125Miniport.EventLog]
AddReg = RTL8125Miniport.EventLog.Reg

[RTL8125Miniport.EventLog.Reg]
HKR, , EventMessageFile, 0x00020000, "%%SystemRoot%%\System32\netevent.dll"
HKR, , TypesSupported,   0x00010001, 7

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
rtl8125miniport.sys = 1,,

[DestinationDirs]
