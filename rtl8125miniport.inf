[ControlFlags]
ExcludeFromSelect = *

[RTL8125Miniport.ndi.NT]
Characteristics    = 0x84
BusType            = 5
*IfType            = 0x6
*MediaType         = 0x0
*PhysicalMediaType = 14
AddReg             = RTL8125Miniport.Reg
AddReg             = RTL8125Miniport.Advanced.Reg
CopyFiles          = RTL8125Miniport.CopyFiles

[RTL8125Miniport.ndi.NT.Services]
AddService = RTL8125MiniportV3, 2, RTL8125Miniport.Service, RTL8125Miniport.EventLog

[RTL8125Miniport.Reg]
HKR, Ndi, Service, 0, "RTL8125MiniportV3"
HKR, Ndi\Interfaces, UpperRange, 0, "ndis5"
HKR, Ndi\Interfaces, LowerRange, 0, "ethernet"

[RTL8125Miniport.Advanced.Reg]
HKR, Ndi\Params\*RSS, ParamDesc, 0, %RSSParamDesc%
HKR, Ndi\Params\*RSS, default, 0, "0"
HKR, Ndi\Params\*RSS, type, 0, "enum"
HKR, Ndi\Params\*RSS\Enum, "0", 0, %Disabled%
HKR, Ndi\Params\*RSS\Enum, "1", 0, %Enabled%

HKR, Ndi\Params\*NumRssQueues, ParamDesc, 0, %NumRssQueuesParamDesc%
HKR, Ndi\Params\*NumRssQueues, default, 0, "1"
HKR, Ndi\Params\*NumRssQueues, type, 0, "int"
HKR, Ndi\Params\*NumRssQueues, min, 0, "1"
HKR, Ndi\Params\*NumRssQueues, max, 0, "4"
HKR, Ndi\Params\*NumRssQueues, step, 0, "1"

HKR, Ndi\Params\*JumboPacket, ParamDesc, 0, %JumboParamDesc%
HKR, Ndi\Params\*JumboPacket, default, 0, "1500"
HKR, Ndi\Params\*JumboPacket, type, 0, "int"
HKR, Ndi\Params\*JumboPacket, min, 0, "1500"
HKR, Ndi\Params\*JumboPacket, max, 0, "9000"
HKR, Ndi\Params\*JumboPacket, step, 0, "1"

HKR, Ndi\Params\*IPChecksumOffloadIPv4, ParamDesc, 0, %IPChecksumIPv4ParamDesc%
